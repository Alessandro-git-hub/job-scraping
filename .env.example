# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Ollama (Local AI) ─────────────────────────
# Optional. Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Optional. Model to use (default: llama3.2)
# Popular choices: llama3.2, llama3.1, mistral, phi3
# Run 'ollama list' to see installed models.
OLLAMA_MODEL=llama3.2

# ── SerpApi ───────────────────────────────────
# Required. Get your key at https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here

# ── Job Sources ───────────────────────────────
# Comma-separated list of sources to enable.
# Free (no API key): google_jobs, remoteok, arbeitnow, himalayas, remotees
#   - google_jobs   — Google Jobs via SerpApi (aggregates LinkedIn, Indeed, Glassdoor, etc.)
#   - remoteok      — RemoteOK (global remote jobs, English only)
#   - arbeitnow     — Arbeitnow (European remote jobs, English only)
#   - himalayas     — Himalayas (global remote jobs, English only)
#   - remotees      — Spanish company job boards (Spain-specific, free)
# Note: remoteok, arbeitnow, and himalayas only return results for English queries.
JOB_SOURCES=google_jobs,remoteok,arbeitnow,himalayas,remotees

# ── Search Queries ────────────────────────────
# Comma-separated job titles / keywords to search for.
# Each query × location combination = 1 API call — keep this list focused.
# Include both English and Spanish variants if searching in Spain.
# Examples:
#   Frontend:   frontend developer,react developer,vue.js developer,desarrollador frontend
#   Backend:    backend developer,node.js developer,python developer,desarrollador backend
#   Design:     ux designer,product designer,diseñador ux,diseñador de producto
#   Data:       data analyst,data scientist,analista de datos
JOB_QUERIES=your job title here,your job title in spanish here

# ── Locations ─────────────────────────────────
# Comma-separated locations to search in.
# For Spain: include "Spain" for national results plus specific cities.
# More locations = more API calls. Start with 2–3 cities.
JOB_LOCATIONS=Spain, Madrid, Barcelona

# ── Keyword Filters ───────────────────────────
# JOB_INCLUDE_KEYWORDS: Only jobs whose TITLE contains at least one of these pass.
# Applied before AI evaluation — used to drop clearly irrelevant titles.
# Leave empty to skip this filter.
# Examples:
#   Frontend: frontend,react,vue,javascript,typescript
#   Design:   designer,ux,ui,product design
#   Data:     data,analyst,scientist,sql
JOB_INCLUDE_KEYWORDS=

# JOB_EXCLUDE_KEYWORDS: Jobs whose title/description contain any of these are discarded.
# Useful for filtering out seniority levels, unrelated departments, etc.
JOB_EXCLUDE_KEYWORDS=senior,sr,

# ── Remote Detection ──────────────────────────
# Keywords used to tag a job as remote in the output (case-insensitive).
# The defaults already cover English + Spanish; edit only if needed.
JOB_REMOTE_KEYWORDS=remote,remoto,teletrabajo,trabajo remoto,100% remoto,fully remote,work from home,desde casa,wfh

# ── Non-English Query Detection ───────────────
# Regex pattern (case-insensitive) to detect non-English queries.
# Queries matching this pattern are skipped on English-only boards
# (remoteok, arbeitnow, himalayas) to avoid wasted calls.
# Default (if not set): detects any accented character (á, é, ñ, ü…),
# which covers Spanish and most other Latin-script languages.
# Override for languages without accents, e.g.:
#   German: \b(entwickler|programmierer|buchhalter)\b
# NON_ENGLISH_QUERY_PATTERN=

# ── Age Filter ────────────────────────────────
# Discard jobs older than this many days. Default: 14.
JOB_MAX_AGE_DAYS=14

# ── Experience Filter ─────────────────────────
# Maximum years of experience a job may require.
# Jobs that explicitly ask for more are discarded before AI evaluation.
# Set to 0 to disable.
MAX_YEARS_EXPERIENCE=0

# ── AI Match Score ────────────────────────────
# Minimum AI fit score (1–10) for a job to be saved.
# 6 = decent match, 7 = good match, 8+ = strong match
MATCH_SCORE_THRESHOLD=6
